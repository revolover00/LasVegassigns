{
  "cleanUrls": true,
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api|assets/|sitemap\\.xml|.*\\..*).*)$",
      "destination": "/index.html"
    }
  ]
}
